{
  "name": "developer-secret-vault",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "vaultx": "./cli/vaultx.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "node --watch server/index.js",
    "dev:web": "vite --host localhost",
    "vaultx": "node cli/vaultx.js",
    "start": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview --host localhost"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "argon2": "^0.43.0",
    "concurrently": "^9.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "lucide-react": "^0.468.0",
    "vite": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {}
}
